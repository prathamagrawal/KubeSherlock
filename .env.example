# KubeSherlock — Environment Variables Reference
# Copy to .env and fill in your values
# NEVER commit .env with real keys to version control

# Kubernetes configuration
KUBECONFIG=~/.kube/config
KUBE_CONTEXT=minikube
ALLOWED_NAMESPACES=default,kube-system

# LLM API keys (add your actual keys here)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-proj-your-key-here

# Logging level
LOG_LEVEL=INFO

# Destructive actions flag (only true for local development)
DESTRUCTIVE_ACTIONS_ENABLED=false

# Watcher settings
WATCHER_ENABLED=true
WATCHER_POLL_INTERVAL=30
WATCHER_NAMESPACES=default,kube-system
WATCHER_RESTART_THRESHOLD=3
WATCHER_COOLDOWN=300
WATCHER_LLM_PROVIDER=anthropic

# Email alerts (optional, for watcher notifications)
# Only HIGH and CRITICAL severity alerts are sent
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=kubesherlock@yourdomain.com
ALERT_EMAIL_TO=oncall@yourdomain.com,devops@yourdomain.com
