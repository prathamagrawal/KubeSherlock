# KubeSherlock — Local Development Environment
# For production, use a proper secrets manager

# ── Kubernetes Configuration ──────────────────────────────────────────────
KUBECONFIG=~/.kube/config
KUBE_CONTEXT=minikube
ALLOWED_NAMESPACES=default,kube-system,db

# ── Agent Configuration ───────────────────────────────────────────────────
# Add your actual keys here for testing. NEVER commit real keys.
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── MCP Server Configuration ──────────────────────────────────────────────
# Enable destructive actions only for local testing. NEVER in production.
DESTRUCTIVE_ACTIONS_ENABLED=false

# ── Watcher Configuration ─────────────────────────────────────────────────
WATCHER_ENABLED=true
WATCHER_POLL_INTERVAL=60
WATCHER_NAMESPACES=default,kube-system,db
WATCHER_RESTART_THRESHOLD=3
WATCHER_COOLDOWN=300
WATCHER_LLM_PROVIDER=openai
WATCHER_EMAIL_ENABLED=true

# ── Email Notification Configuration ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=prathamagrawal1205@gmail.com
SMTP_PASSWORD="ddnl thgt pcgz mean"
SMTP_FROM=prathamagrawal1205@gmail.com
SMTP_USE_TLS=true
ALERT_EMAIL_TO=prathamagrawal1205@gmail.com
