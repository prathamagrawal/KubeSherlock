# KubeSherlock — Local Development Environment
# For production, use a proper secrets manager

# ── Kubernetes Configuration ──────────────────────────────────────────────
KUBECONFIG=CHANGEME
KUBE_CONTEXT=CHANGEME
ALLOWED_NAMESPACES=CHANGEME

# ── Agent Configuration ───────────────────────────────────────────────────
# Add your actual keys here for testing. NEVER commit real keys.
ANTHROPIC_API_KEY=CHANGEME
OPENAI_API_KEY=CHANGEME
# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=CHANGEME

# ── MCP Server Configuration ──────────────────────────────────────────────
# Enable destructive actions only for local testing. NEVER in production.
DESTRUCTIVE_ACTIONS_ENABLED=CHANGEME

# ── Watcher Configuration ─────────────────────────────────────────────────
WATCHER_ENABLED=CHANGEME
WATCHER_POLL_INTERVAL=CHANGEME
WATCHER_NAMESPACES=CHANGEME
WATCHER_RESTART_THRESHOLD=CHANGEME
WATCHER_COOLDOWN=CHANGEME
WATCHER_LLM_PROVIDER=CHANGEME
WATCHER_EMAIL_ENABLED=CHANGEME

# ── Email Notification Configuration ──────────────────────────────────────
SMTP_HOST=CHANGEME
SMTP_PORT=CHANGEME
SMTP_USER=CHANGEME
SMTP_PASSWORD=CHANGEME
SMTP_FROM=CHANGEME
SMTP_USE_TLS=CHANGEME
ALERT_EMAIL_TO=CHANGEME
